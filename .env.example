# .env.example — AutoTrade Sniper V15

# --- SUPABASE ---
VITE_SUPABASE_URL=        # URL du projet Supabase (ex: https://xxx.supabase.co)
VITE_SUPABASE_KEY=        # Clé anon publique Supabase

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=       # Token du bot (depuis @BotFather)
TELEGRAM_CHAT_ID=         # ID du chat (depuis @userinfobot)

# --- GEMINI AI ---
API_KEY=                  # Clé API Gemini (depuis aistudio.google.com/apikey)

# --- BROKER CTRADER (IC Markets) ---
CTRADER_CLIENT_ID=        # Client ID depuis open.ctrader.com
CTRADER_CLIENT_SECRET=    # Client Secret depuis open.ctrader.com
CTRADER_ACCESS_TOKEN=     # Access Token OAuth (~30 jours, obtenu via navigateur)
CTRADER_ACCOUNT_ID=       # ctidTraderAccountId (ex: 9932624)
CTRADER_LIVE=false        # true = compte réel, false = compte démo (défaut)
CTRADER_RISK_PERCENT=1    # % du solde risqué par trade (défaut: 1%)

# --- SÉCURITÉ ---
VITE_APP_PASSWORD=        # Mot de passe d'accès à l'interface web (OBLIGATOIRE, pas de défaut)
API_SECRET_TOKEN=         # Token Bearer pour les routes admin serveur (généré: openssl rand -hex 32)
AUTONOMOUS_MIN_CONFIDENCE=75  # Seuil de confiance minimum pour l'exécution autonome (0-100)
