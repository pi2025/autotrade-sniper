# .env.example
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
API_KEY= # Clé Gemini API

# --- BROKER OANDA ---
OANDA_API_KEY=          # Clé API OANDA (Personal Access Token)
OANDA_ACCOUNT_ID=       # ID du compte (ex: 001-001-XXXXXXX-001)
OANDA_LIVE=false        # true = compte réel, false = compte démo (défaut)
OANDA_RISK_PERCENT=1    # % du solde risqué par trade (défaut: 1%)
AUTONOMOUS_MIN_CONFIDENCE=75  # Seuil de confiance minimum pour l'exécution autonome (0-100)

# --- SÉCURITÉ API ---
API_SECRET_TOKEN=       # Token Bearer pour les routes sensibles du serveur
